generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  FAN
  AIR_COOLER
  MOBILE_AC
  AIR_PURIFIER
  DEHUMIDIFIER
  HEATER
  RADIATOR
  HUMIDIFIER
  THERMOSTAT
  WASHING_MACHINE
  DISHWASHER
  FRIDGE
  TUMBLE_DRYER
  FREEZER
  OVEN
  COOKTOP
  HOOD
  WINE_CELLAR
  COFFEE_MACHINE
  AIR_FRYER
  COOKING_ROBOT
  KETTLE
  TOASTER
  BLENDER
}

model Product {
  id          String   @id @default(cuid())
  name        String
  brand       String
  category    Category
  description String?
  image       String?
  ean         String?  @unique // EAN-13 / GTIN — master cross-merchant key (null until sourced)
  mpn         String // manufacturer part number / référence constructeur
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  specifications   ProductSpecification[]
  reviewAggregates ProductReviewAggregate[]
  expertScores     ExpertScore[]
  productScore     ProductScore?
  offers           Offer[]

  @@unique([brand, mpn]) // (brand, MPN) uniquely identifies a model when EAN is absent
  @@index([category])
  @@index([brand])
}

model Offer {
  id          String   @id @default(cuid())
  productId   String
  merchant    String // "Amazon" | "Darty" | "Fnac" | "Boulanger"
  merchantSku String? // ASIN / merchant product id, once the exact listing is resolved
  url         String // canonical product URL (or precise EAN/MPN search until resolved)
  // True when `url` is already an affiliate-tracked deeplink (e.g. Awin aw_deep_link)
  // → /api/go redirects to it as-is instead of re-wrapping.
  isAffiliateUrl Boolean @default(false)
  price       Float
  currency    String   @default("EUR")
  inStock     Boolean  @default(true)
  lastUpdated DateTime @default(now())

  // Outbound click tracking (revenue attribution).
  clickCount    Int       @default(0)
  lastClickedAt DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, merchant])
  @@index([productId])
  @@index([productId, price])
}

model ProductSpecification {
  id        String  @id @default(cuid())
  productId String
  key       String
  value     String
  unit      String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([productId])
}

model ReviewSource {
  id         String @id @default(cuid())
  name       String @unique
  type       String // "generalist" | "specialist"
  trustScore Float  // 0-1

  reviewAggregates ProductReviewAggregate[]
}

model ProductReviewAggregate {
  id          String   @id @default(cuid())
  productId   String
  sourceId    String
  rating      Float    // 0-5
  reviewCount Int
  lastUpdated DateTime @default(now())

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  source  ReviewSource @relation(fields: [sourceId], references: [id])

  @@unique([productId, sourceId])
  @@index([productId])
}

model ExpertScore {
  id         String @id @default(cuid())
  productId  String
  sourceName String
  score      Float  // 0-20
  weight     Float  @default(1.0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sourceName])
  @@index([productId])
}

model ProductScore {
  id               String   @id @default(cuid())
  productId        String   @unique
  userScore        Float    // 0-20
  expertScore      Float    // 0-20
  technicalScore   Float    // 0-20
  finalScore       Float    // 0-20
  confidenceScore  Float    // 0-100
  lastCalculatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([finalScore])
}
